---
import BaseHead from '../layouts/BaseHead.astro';

const tools = [
  { emoji: "🔥", name: "BMR & TDEE Calculator", desc: "How many calories do you actually burn? Calculate your basal metabolic rate and total daily energy expenditure.", soon: true },
  { emoji: "🏋️", name: "One Rep Max (1RM)", desc: "Estimate your max lift from any rep range. Supports Epley, Brzycki, and Lombardi formulas.", soon: true },
  { emoji: "💧", name: "Hydration Target", desc: "How much water should you drink? Personalized daily target based on weight, activity, and climate.", soon: true },
  { emoji: "🥩", name: "Macro Splitter", desc: "Hit your protein, carb, and fat targets. Split macros by meal count and see grams per meal.", soon: true },
  { emoji: "🧱", name: "Concrete Yardage Calculator", desc: "How much concrete for your slab, footing, or post hole? Cubic yards with 10% waste factor built in.", soon: true },
  { emoji: "🎨", name: "Paint Coverage Calculator", desc: "How many gallons for your room? Enter dimensions, doors, and windows — get the exact amount.", soon: true },
  { emoji: "🪵", name: "Lumber Board-Foot Calculator", desc: "Calculate board feet for your woodworking project. Price per board foot included.", soon: true },
];
---
<html lang="en">
<head>
  <BaseHead
    title="I Just Want To Live — Health Calculators, Macro Trackers & Home DIY Guides"
    description="Free health and DIY calculators. BMR, TDEE, one rep max, hydration targets, concrete yardage, paint coverage, and lumber board-foot calculators. No signup, no BS."
    ogTitle="I Just Want To Live — Health & DIY Calculators"
    ogDescription="BMR, macros, 1RM, hydration, concrete, paint, lumber — free calculators for living your best life."
  />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #060c0a; color: #c8e0d8; }
    .hero { text-align: center; padding: 100px 24px 80px; background: linear-gradient(180deg, #0a1a15 0%, #060c0a 100%); position: relative; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(26,122,109,0.08) 0%, transparent 60%); }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 { font-size: 3rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; background: linear-gradient(135deg, #fff 0%, #2DB89A 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero p { color: #666; font-size: 1.05rem; max-width: 480px; margin: 0 auto; }
    .grid { max-width: 900px; margin: 0 auto; padding: 0 24px 100px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .card { background: #0c1410; border: 2px solid #1a2a24; border-radius: 16px; padding: 28px 24px; position: relative; }
    .card .emoji { font-size: 2rem; margin-bottom: 12px; display: block; }
    .card h2 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
    .card p { font-size: 0.85rem; color: #888; line-height: 1.6; }
    .badge { position: absolute; top: 14px; right: 14px; background: #1a2a24; color: #2DB89A; font-size: 0.65rem; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #333; border-top: 1px solid #0f1a15; }
    .footer a { color: #2DB89A; text-decoration: none; }
    @media (max-width: 600px) { .hero h1 { font-size: 2.2rem; } .hero { padding: 70px 20px 50px; } .grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<div class="hero">
  <div class="hero-content">
    <h1>ijustwantto.live 💪</h1>
    <p>Simple calculators for health, fitness, and building things with your hands.</p>
  </div>
</div>
<div class="grid">
  {tools.map(t => (
    <div class="card">
      {t.soon && <span class="badge">COMING SOON</span>}
      <span class="emoji">{t.emoji}</span>
      <h2>{t.name}</h2>
      <p>{t.desc}</p>
    </div>
  ))}
</div>
<div class="footer">© 2025 <a href="https://ijustwantto.live">ijustwantto.live</a> · A <a href="https://gab.ae">GAB Ventures</a> property</div>
</body>
</html>
