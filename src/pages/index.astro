---
import BaseHead from '../layouts/BaseHead.astro';

const tools = [
  { emoji: "🔥", name: "BMR & TDEE Calculator", slug: "/bmr-calculator", desc: "How many calories do you actually burn? Calculate your basal metabolic rate and total daily energy expenditure." },
  { emoji: "🏋️", name: "One Rep Max (1RM)", slug: "/one-rep-max", desc: "Estimate your max lift from any rep range. Supports Epley, Brzycki, and Lombardi formulas." },
  { emoji: "💧", name: "Water Intake Calculator", slug: "/water-intake", desc: "Calculate your daily water needs based on weight, activity level, and climate. Recommended intake in glasses, liters, and ounces." },
  { emoji: "🥩", name: "Macro Calculator", slug: "/macro-calculator", desc: "Calculate daily macronutrient targets for cutting, maintenance, or bulking. Balanced, High Protein, Low Carb, and Keto splits." },
  { emoji: "🔥", name: "Calorie Deficit Calculator", slug: "/calorie-deficit", desc: "Calculate your calorie deficit for weight loss. Weekly and monthly projections, daily calorie goals, and safety warnings." },
  { emoji: "📏", name: "Body Fat Calculator", slug: "/body-fat", desc: "Calculate your body fat percentage using the U.S. Navy Method or Jackson-Pollock 3-Site Skinfold Method." },
  { emoji: "⚖️", name: "Ideal Weight Calculator", slug: "/ideal-weight", desc: "Calculate your ideal weight using BMI, Devine, Robinson, and Hamwi formulas. Find your healthy weight range." },
  { emoji: "❤️", name: "Heart Rate Zone Calculator", slug: "/heart-rate-zones", desc: "Personalized heart rate training zones using the Karvonen method. Fat burn, cardio, threshold, and VO2 max zones." },
  { emoji: "🧱", name: "Concrete Yardage Calculator", slug: "/concrete-calculator", desc: "How much concrete for your slab, footing, or post hole? Cubic yards with 10% waste factor built in." },
  { emoji: "😴", name: "Sleep Cycle Calculator", slug: "/sleep-cycle", desc: "Find the best time to wake up or go to bed based on 90-minute sleep cycles." },
  { emoji: "🏃", name: "Pace Calculator", slug: "/pace-calculator", desc: "Calculate your running pace, finish time, or distance. Supports miles and kilometers." },
  { emoji: "🫁", name: "VO2 Max Estimator", slug: "/vo2max-estimator", desc: "Estimate your VO2 max from a timed run. See your cardio fitness level and age comparison." },
  { emoji: "⏱️", name: "Interval Timer", slug: "/interval-timer", desc: "Customizable interval timer for HIIT, Tabata, and circuit training. Audio cues included." },
  { emoji: "🎨", name: "Paint Coverage Calculator", slug: "/paint-calculator", desc: "How many gallons for your room? Enter dimensions, doors, and windows — get the exact amount." },
  { emoji: "🔲", name: "Tile Calculator", slug: "/tile-calculator", desc: "Calculate how many tiles you need for floors or walls. Accounts for waste and cuts." },
  { emoji: "🪵", name: "Deck Calculator", slug: "/deck-calculator", desc: "Estimate decking boards, joists, and hardware for your deck build." },
  { emoji: "🪨", name: "Gravel Calculator", slug: "/gravel-calculator", desc: "Calculate tons or cubic yards of gravel for driveways, paths, and landscaping." },
  { emoji: "🪜", name: "Stair Calculator", slug: "/stair-calculator", desc: "Calculate riser height, tread depth, and stringer length for building stairs to code." },
  { emoji: "📐", name: "Roof Pitch Calculator", slug: "/roof-pitch", desc: "Calculate roof pitch, angle, and rafter length from rise and run measurements." },
  { emoji: "🧱", name: "Drywall Calculator", slug: "/drywall-calculator", desc: "Calculate how many drywall sheets you need for your room. Accounts for doors, windows, and waste." },
  { emoji: "🌡️", name: "BTU Calculator", slug: "/btu-calculator", desc: "Calculate the BTU heating or cooling capacity you need for any room. Based on square footage and insulation." },
  { emoji: "☀️", name: "Solar Calculator", slug: "/solar-calculator", desc: "Estimate solar panel system size, cost, and savings for your home based on energy usage and location." },
  { emoji: "⚖️", name: "BMI Calculator", slug: "/bmi-calculator", desc: "Calculate your Body Mass Index and see where you fall on the WHO scale. Quick, simple, no signup." },
  { emoji: "🏠", name: "Home Gym Setup Guide", slug: "/guide-home-gym", desc: "Everything you need to build a home gym on any budget. Equipment lists, layout tips, and flooring recommendations." },
  { emoji: "🥗", name: "Meal Prep Guide", slug: "/guide-meal-prep", desc: "Step-by-step meal prep guide for beginners. Weekly plans, grocery lists, and batch cooking tips." },
  { emoji: "🪵", name: "Board Foot Calculator", slug: "/lumber-calculator", desc: "Board feet for lumber. Thickness, width, length. Batch mode. Waste." },
  { emoji: "📐", name: "Square Footage Calculator", slug: "/sqft-calculator", desc: "Square footage for rooms. Rectangular, triangular, circular. Multiple areas." },
  { emoji: "👶", name: "Pregnancy Due Date Calculator", slug: "/pregnancy-calculator", desc: "Due date from LMP or conception. Trimester timeline. Milestones." },
  { emoji: "📚", name: "Home Insulation Guide", slug: "/guide-insulation", desc: "Types of insulation: fiberglass, spray foam, cellulose, mineral wool. R-values by climate zone." },
  { emoji: "📚", name: "How to Paint a Room Like a Pro", slug: "/guide-paint-room", desc: "Step-by-step room painting guide. Prep, primer, cutting in, rolling, cleanup. Tool list." },
];
---
<html lang="en">
<head>
  <BaseHead
    title="I Just Want To Live — Health Calculators, Macro Trackers & Home DIY Guides"
    description="Free health and DIY calculators. BMR, TDEE, one rep max, hydration targets, concrete yardage, paint coverage, and lumber board-foot calculators. No signup, no BS."
    ogTitle="I Just Want To Live — Health & DIY Calculators"
    ogDescription="BMR, macros, 1RM, hydration, concrete, paint, lumber — free calculators for living your best life."
  />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #060c0a; color: #c8e0d8; }
    .hero { text-align: center; padding: 100px 24px 80px; background: linear-gradient(180deg, #0a1a15 0%, #060c0a 100%); position: relative; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(26,122,109,0.08) 0%, transparent 60%); }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 { font-size: 3rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; background: linear-gradient(135deg, #fff 0%, #2DB89A 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero p { color: #666; font-size: 1.05rem; max-width: 480px; margin: 0 auto; }
    .grid { max-width: 900px; margin: 0 auto; padding: 0 24px 100px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .card { background: #0c1410; border: 2px solid #1a2a24; border-radius: 16px; padding: 28px 24px; position: relative; }
    .card .emoji { font-size: 2rem; margin-bottom: 12px; display: block; }
    .card h2 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
    .card p { font-size: 0.85rem; color: #888; line-height: 1.6; }
    a.card { text-decoration: none; color: inherit; cursor: pointer; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
    a.card:hover { border-color: #2DB89A; transform: translateY(-3px); box-shadow: 0 8px 30px rgba(45,184,154,0.1); }
    .arrow { color: #2DB89A; font-size: 0.85rem; margin-top: 14px; display: inline-block; font-weight: 600; }
    .badge { position: absolute; top: 14px; right: 14px; background: #1a2a24; color: #2DB89A; font-size: 0.65rem; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .live-badge { background: #1a2a1a; color: #4ade80; }
    .footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #333; border-top: 1px solid #0f1a15; }
    .footer a { color: #2DB89A; text-decoration: none; }
    @media (max-width: 600px) { .hero h1 { font-size: 2.2rem; } .hero { padding: 70px 20px 50px; } .grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<div class="hero">
  <div class="hero-content">
    <h1>ijustwantto.live 💪</h1>
    <p>Simple calculators for health, fitness, and building things with your hands.</p>
  </div>
</div>
<div class="grid">
  {tools.map(t => t.slug ? (
    <a class="card live" href={t.slug}>
      <span class="badge live-badge">LIVE</span>
      <span class="emoji">{t.emoji}</span>
      <h2>{t.name}</h2>
      <p>{t.desc}</p>
      <span class="arrow">Try it →</span>
    </a>
  ) : (
    <div class="card">
      <span class="badge">COMING SOON</span>
      <span class="emoji">{t.emoji}</span>
      <h2>{t.name}</h2>
      <p>{t.desc}</p>
    </div>
  ))}
</div>
<div class="footer">© 2025 <a href="https://ijustwantto.live">ijustwantto.live</a> · A <a href="https://gab.ae">GAB Ventures</a> property</div>
</body>
</html>
