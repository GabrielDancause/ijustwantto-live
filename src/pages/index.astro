---
import BaseHead from '../layouts/BaseHead.astro';

// Tools (health, fitness and DIY calculators)
const tools = [
  { emoji: "🔥", name: "BMR & TDEE Calculator", slug: "/bmr-calculator", desc: "Calculate your basal metabolic rate and total daily energy expenditure" },
  { emoji: "🏋️", name: "One Rep Max Calculator", slug: "/one-rep-max", desc: "Estimate your max lift from any rep range with multiple formulas" },
  { emoji: "💧", name: "Water Intake Calculator", slug: "/water-intake", desc: "Calculate daily water needs based on weight, activity, and climate" },
  { emoji: "🥩", name: "Macro Calculator", slug: "/macro-calculator", desc: "Daily macronutrient targets for cutting, maintenance, or bulking" },
  { emoji: "🔥", name: "Calorie Deficit Calculator", slug: "/calorie-deficit", desc: "Calculate calorie deficit for weight loss with safety warnings" },
  { emoji: "📏", name: "Body Fat Calculator", slug: "/body-fat", desc: "Body fat percentage using U.S. Navy or Jackson-Pollock methods" },
  { emoji: "⚖️", name: "Ideal Weight Calculator", slug: "/ideal-weight", desc: "Ideal weight using BMI, Devine, Robinson, and Hamwi formulas" },
  { emoji: "❤️", name: "Heart Rate Zone Calculator", slug: "/heart-rate-zones", desc: "Personalized training zones using the Karvonen method" },
  { emoji: "⚖️", name: "BMI Calculator", slug: "/bmi-calculator", desc: "Calculate Body Mass Index and see where you fall on the scale" },
  { emoji: "😴", name: "Sleep Cycle Calculator", slug: "/sleep-cycle", desc: "Find best bedtime or wake time based on 90-minute cycles" },
  { emoji: "🏃", name: "Pace Calculator", slug: "/pace-calculator", desc: "Calculate running pace, finish time, or distance" },
  { emoji: "🫁", name: "VO2 Max Estimator", slug: "/vo2max-estimator", desc: "Estimate VO2 max from timed run with fitness comparisons" },
  { emoji: "⏱️", name: "Interval Timer", slug: "/interval-timer", desc: "Customizable timer for HIIT, Tabata, circuit training" },
  { emoji: "👶", name: "Pregnancy Due Date Calculator", slug: "/pregnancy-calculator", desc: "Due date from LMP or conception with trimester timeline" },
  { emoji: "🧱", name: "Concrete Calculator", slug: "/concrete-calculator", desc: "Cubic yards for slabs, footings, post holes with waste factor" },
  { emoji: "🎨", name: "Paint Coverage Calculator", slug: "/paint-calculator", desc: "How many gallons needed for rooms with doors and windows" },
  { emoji: "🔲", name: "Tile Calculator", slug: "/tile-calculator", desc: "Calculate tiles needed for floors or walls with waste factor" },
  { emoji: "🪵", name: "Deck Calculator", slug: "/deck-calculator", desc: "Estimate decking boards, joists, and hardware for deck builds" },
  { emoji: "🪨", name: "Gravel Calculator", slug: "/gravel-calculator", desc: "Calculate tons or cubic yards for driveways and landscaping" },
  { emoji: "🪜", name: "Stair Calculator", slug: "/stair-calculator", desc: "Calculate riser height, tread depth, stringer length to code" },
  { emoji: "📐", name: "Roof Pitch Calculator", slug: "/roof-pitch", desc: "Calculate roof pitch, angle, and rafter length from measurements" },
  { emoji: "🧱", name: "Drywall Calculator", slug: "/drywall-calculator", desc: "Calculate drywall sheets needed with doors, windows, waste" },
  { emoji: "🌡️", name: "BTU Calculator", slug: "/btu-calculator", desc: "Calculate BTU heating/cooling capacity needed for rooms" },
  { emoji: "☀️", name: "Solar Calculator", slug: "/solar-calculator", desc: "Estimate solar panel system size, cost, and savings" },
  { emoji: "🪵", name: "Board Foot Calculator", slug: "/lumber-calculator", desc: "Calculate board feet for lumber with waste factor" },
  { emoji: "📐", name: "Square Footage Calculator", slug: "/sqft-calculator", desc: "Calculate square footage for rectangular, triangular, circular areas" },
  { emoji: "🏡", name: "Fence Calculator", slug: "/fence-calculator", desc: "Fence materials: posts, rails, pickets, concrete with cost estimate" }
];

// Studies (none for this domain)
const studies = [
  {
  title: "Gym Membership Costs Compared 2026",
  subtitle: "23 chains analyzed",
  slug: "/gym-costs",
  stat: "23",
  statLabel: "Gyms Compared",
  desc: "Analyzed pricing and amenities across 23 major gym chains. Found base prices starting as low as $10/month at Planet Fitness, Blink, and Chuze.",
  tag: "ORIGINAL RESEARCH",
}
];

// Guides
const guides = [
  { emoji: "🏠", name: "Home Gym Setup Guide", slug: "/guide-home-gym", desc: "Build a home gym on any budget with equipment and layout tips" },
  { emoji: "🥗", name: "Meal Prep Guide", slug: "/guide-meal-prep", desc: "Weekly meal prep plans, grocery lists, and batch cooking tips" },
  { emoji: "📚", name: "Home Insulation Guide", slug: "/guide-insulation", desc: "Types of insulation and R-values by climate zone" },
  { emoji: "📚", name: "How to Paint a Room Like a Pro", slug: "/guide-paint-room", desc: "Step-by-step painting guide with prep, primer, tools" },
  { emoji: "🏃", name: "Couch to 5K Running Plan", slug: "/guide-running-plan", desc: "8-week running plan for beginners with injury prevention" }
];

// Lists
const lists = [
  { emoji: "🛠️", name: "Essential Home Tools", slug: "/list-home-tools", desc: "Must-have tools for homeowners: hand tools, power tools, safety gear" },
  { emoji: "🌬️", name: "Best Air Purifiers", slug: "/list-air-purifiers", desc: "Compare air purifiers by room size, filter type, noise, price" },
  { emoji: "🪑", name: "Best Standing Desks", slug: "/list-standing-desks", desc: "Compare standing desks by height range, stability, presets, price" }
];
---
<html lang="en">
<head>
  <BaseHead />
  <title>ijustwantto.live — Practical Life Tools</title>
  <meta name="description" content="Free health and DIY calculators. BMR, TDEE, one rep max, hydration targets, concrete yardage, paint coverage, and lumber board-foot calculators." />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, sans-serif; 
      background: #060a12; 
      color: #c8d0de; 
      line-height: 1.6;
    }

    /* Hero */
    .hero { 
      text-align: center; 
      padding: 100px 24px 70px; 
      background: linear-gradient(180deg, #0a1a15 0%, #060a12 100%); 
      position: relative; 
    }
    .hero::before { 
      content: ''; 
      position: absolute; 
      inset: 0; 
      background: radial-gradient(circle at 50% 40%, rgba(45,184,154,0.08) 0%, transparent 60%); 
    }
    .hero-content { position: relative; z-index: 1; }
    .hero .tagline { 
      color: #2DB89A; 
      font-size: 0.85rem; 
      font-weight: 700; 
      letter-spacing: 3px; 
      text-transform: uppercase; 
      margin-bottom: 16px; 
    }
    .hero h1 { 
      font-size: 3rem; 
      font-weight: 900; 
      letter-spacing: -1.5px; 
      margin-bottom: 20px; 
      background: linear-gradient(135deg, #fff 0%, #2DB89A 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p { 
      color: #5a6a80; 
      font-size: 1.05rem; 
      max-width: 520px; 
      margin: 0 auto; 
    }

    /* Sections */
    .section-container { 
      max-width: 1200px; 
      margin: 0 auto; 
      padding: 60px 24px; 
    }
    .section-header { 
      text-align: center; 
      margin-bottom: 40px; 
    }
    .section-tag { 
      display: inline-block; 
      background: rgba(45,184,154,0.1); 
      color: #2DB89A; 
      font-size: 0.7rem; 
      font-weight: 800; 
      padding: 6px 16px; 
      border-radius: 20px; 
      letter-spacing: 1px; 
      margin-bottom: 12px; 
    }
    .section-title { 
      font-size: 2.2rem; 
      font-weight: 900; 
      color: #fff; 
      margin-bottom: 8px; 
      letter-spacing: -0.8px; 
    }
    .section-sub { 
      color: #5a6a80; 
      font-size: 1rem; 
    }

    /* Tools Grid */
    .tools-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
      gap: 16px; 
    }
    .tool-card { 
      background: #0c1410; 
      border: 1px solid #1a2a24; 
      border-radius: 12px; 
      padding: 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .tool-card:hover { 
      border-color: #2DB89A; 
      transform: translateY(-2px); 
    }
    .tool-emoji { 
      font-size: 1.4rem; 
      margin-bottom: 8px; 
      display: block; 
    }
    .tool-name { 
      font-size: 0.95rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .tool-desc { 
      font-size: 0.8rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Guides & Lists Grid */
    .guides-grid, .lists-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
      gap: 20px; 
    }
    .guide-card, .list-card { 
      background: #0c1410; 
      border: 1px solid #1a2a24; 
      border-radius: 14px; 
      padding: 24px 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .guide-card:hover, .list-card:hover { 
      border-color: #2DB89A; 
      transform: translateY(-2px); 
    }
    .guide-emoji, .list-emoji { 
      font-size: 1.5rem; 
      margin-bottom: 10px; 
      display: block; 
    }
    .guide-name, .list-name { 
      font-size: 1rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .guide-desc, .list-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Footer */
    .footer { 
      text-align: center; 
      padding: 50px 24px; 
      font-size: 0.85rem; 
      color: #3a4a5a; 
      border-top: 1px solid #151f2e; 
      background: #040810; 
    }
    .footer a { 
      color: #2DB89A; 
      text-decoration: none; 
    }
    .footer a:hover { 
      text-decoration: underline; 
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero h1 { font-size: 2.2rem; }
      .hero { padding: 70px 20px 50px; }
      .section-container { padding: 40px 20px; }
      .tools-grid, .guides-grid, .lists-grid { 
        grid-template-columns: 1fr; 
      }
    }
  </style>
</head>
<body>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Practical Life Tools</div>
      <h1>ijustwantto.live</h1>
      <p>Simple calculators for health, fitness, and building things with your hands.</p>
    </div>
  </div>

  <!-- Tools Section -->
  {tools.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🛠️ TOOLS</span>
        <h2 class="section-title">Life Calculators</h2>
        <p class="section-sub">Health, fitness, and DIY calculators for everyday life.</p>
      </div>
      <div class="tools-grid">
        {tools.map(tool => (
          <a class="tool-card" href={tool.slug}>
            <span class="tool-emoji">{tool.emoji}</span>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}


  <!-- Studies Section -->
  {studies.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🔬 ORIGINAL RESEARCH</span>
        <h2 class="section-title">Studies & Reports</h2>
        <p class="section-sub">Data-driven analysis and insights.</p>
      </div>
      <div class="studies-grid" style="display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 40px;">
        {studies.map(study => (
          <a class="study-card" href={study.slug} style="background: #0c1410; border: 1px solid #1a2a24; border-radius: 14px; padding: 32px; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 16px; transition: all 0.2s ease;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <div>
                <span style="color: #2DB89A; font-size: 0.75rem; font-weight: 800; letter-spacing: 1px;">{study.tag}</span>
                <h3 style="font-size: 1.5rem; font-weight: 800; color: #fff; margin-top: 8px;">{study.title}</h3>
                <p style="color: #6a7a90; font-size: 0.95rem; margin-top: 4px;">{study.subtitle}</p>
              </div>
              <div style="text-align: right; background: rgba(45,184,154,0.1); padding: 12px 20px; border-radius: 8px;">
                <div style="color: #fff; font-size: 1.8rem; font-weight: 800; font-family: 'JetBrains Mono', monospace; line-height: 1;">{study.stat}</div>
                <div style="color: #2DB89A; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; margin-top: 4px;">{study.statLabel}</div>
              </div>
            </div>
            <p style="color: #e0e8f0; font-size: 1.05rem; line-height: 1.6; padding-top: 16px; border-top: 1px solid #1a2a24;">{study.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

<!-- Guides Section -->
  {guides.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📚 GUIDES</span>
        <h2 class="section-title">Practical Guides</h2>
        <p class="section-sub">Step-by-step guides for better living and home improvement.</p>
      </div>
      <div class="guides-grid">
        {guides.map(guide => (
          <a class="guide-card" href={guide.slug}>
            <span class="guide-emoji">{guide.emoji}</span>
            <h3 class="guide-name">{guide.name}</h3>
            <p class="guide-desc">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Lists Section -->
  {lists.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📋 LISTS</span>
        <h2 class="section-title">Curated Lists</h2>
        <p class="section-sub">Best tools, equipment, and products for practical living.</p>
      </div>
      <div class="lists-grid">
        {lists.map(list => (
          <a class="list-card" href={list.slug}>
            <span class="list-emoji">{list.emoji}</span>
            <h3 class="list-name">{list.name}</h3>
            <p class="list-desc">{list.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="footer">
    © 2026 <a href="/">ijustwantto.live</a> · A <a href="https://gab.ae">GAB Ventures</a> property
  </div>
</body>
</html>